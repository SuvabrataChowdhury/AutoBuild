{
  "realm": "SpringBootRealm",
  "enabled": true,
  "clients": [
    {
      "clientId": "pipeline-service",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "PIPELINE_ADMIN"
      },
      {
        "name": "USER"
      }
    ]
  },
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "test@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ],
      "realmRoles": ["PIPELINE_ADMIN", "USER"]
    }
  ]
}
