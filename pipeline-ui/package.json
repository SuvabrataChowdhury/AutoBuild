{
  "name": "pipeline-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "local-e2e": "vite --mode local-e2e",
    "production": "vite build && vite preview",
    "local-with-mock": "concurrently \"npm run mock\" \"vite --mode local-with-mock\"",
    "build": "tsc -b && vite build",
    "mock": "prism mock ./../apis/openapi-spec/pipeline-service.yaml -d",
    "lint": "eslint src",
    "preview": "vite preview",
    "test": "vitest",
    "test:local": "vitest --ui",
    "test:coverage-pipeline": "vitest run --coverage --no-color",
    "generate:clean": "rm -rf ./src/gen",
    "generate:client-code": "openapi-generator-cli generate",
    "generate:clean-client-code": "npm run generate:clean && npm run generate:client-code"
  },
  "dependencies": {
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@stoplight/prism-cli": "^5.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}